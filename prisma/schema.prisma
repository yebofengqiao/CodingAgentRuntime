generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("MYSQL_URL")
}

model Conversation {
  id              String            @id @db.VarChar(36)
  executionStatus String            @map("execution_status") @db.VarChar(64)
  lastSeq         Int               @default(0) @map("last_seq")
  createdAt       DateTime          @map("created_at")
  updatedAt       DateTime          @map("updated_at")
  lastEventAt     DateTime?         @map("last_event_at")
  runs            ConversationRun[]

  @@map("conversation")
}

model ConversationRun {
  id              String       @id @db.VarChar(36)
  conversationId  String       @map("conversation_id") @db.VarChar(36)
  status          String       @db.VarChar(64)
  waitingActionId String?      @map("waiting_action_id") @db.VarChar(191)
  errorDetail     String?      @map("error_detail") @db.Text
  createdAt       DateTime     @map("created_at")
  updatedAt       DateTime     @map("updated_at")
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("conversation_run")
}

model EvaluationExperiment {
  id                   String          @id @db.VarChar(36)
  name                 String          @db.VarChar(191)
  mode                 String          @default("strategy") @db.VarChar(64)
  status               String          @db.VarChar(64)
  caseIds              Json            @map("case_ids")
  baselineVariantId    String          @map("baseline_variant_id") @db.VarChar(191)
  comparisonVariantIds Json            @map("comparison_variant_ids")
  aggregatePayload     Json            @map("aggregate_payload")
  reportPaths          Json            @map("report_paths")
  totalRuns            Int             @map("total_runs")
  completedRuns        Int             @map("completed_runs")
  failedRuns           Int             @map("failed_runs")
  errorMessage         String?         @map("error_message") @db.Text
  createdAt            DateTime        @map("created_at")
  updatedAt            DateTime        @map("updated_at")
  startedAt            DateTime?       @map("started_at")
  finishedAt           DateTime?       @map("finished_at")
  runs                 EvaluationRun[]

  @@index([createdAt(sort: Desc)])
  @@map("evaluation_experiment")
}

model EvaluationRun {
  id             String               @id @db.VarChar(36)
  experimentId   String               @map("experiment_id") @db.VarChar(36)
  caseId         String               @map("case_id") @db.VarChar(191)
  variantId      String               @map("variant_id") @db.VarChar(191)
  replicaIndex   Int                  @default(1) @map("replica_index")
  status         String               @db.VarChar(64)
  metrics        Json
  judgePayload   Json                 @map("judge_payload")
  failureTaxonomy Json                @map("failure_taxonomy")
  artifactPaths  Json                 @map("artifact_paths")
  resultPayload  Json                 @map("result_payload")
  errorMessage   String?              @map("error_message") @db.Text
  lockedBy       String?              @map("locked_by") @db.VarChar(191)
  createdAt      DateTime             @map("created_at")
  updatedAt      DateTime             @map("updated_at")
  startedAt      DateTime?            @map("started_at")
  finishedAt     DateTime?            @map("finished_at")
  experiment     EvaluationExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId])
  @@index([status, createdAt(sort: Asc)])
  @@index([caseId])
  @@index([variantId])
  @@unique([experimentId, caseId, variantId, replicaIndex])
  @@map("evaluation_run")
}
